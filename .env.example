# ===== Database =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=healthroute
POSTGRES_USER=healthroute
POSTGRES_PASSWORD=changeme_in_production

# ===== API Keys =====
WAQI_API_TOKEN=your_waqi_token_here
TOMTOM_API_KEY=your_tomtom_key_here

# CPCB Real-Time AQI (data.gov.in)
# Register: https://data.gov.in → search "CPCB Real Time Air Quality Index"
# Resource ID: 3b01bcb8-0b14-4abf-b6f2-c1bfd384ba69 (free, instant key)
CPCB_API_KEY=your_data_gov_in_api_key_here

# ===== Admin Security =====
# Required to call /api/admin/* endpoints. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Leave blank to disable admin endpoints entirely.
ADMIN_API_KEY=

# ===== Backend =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173

# ===== Live Incident Sources (optional) =====
# Waze CCP: Register at https://developers.google.com/waze
# Bangalore is included in the CCP program. Leave blank until approved.
WAZE_CCP_URL=

# Twitter/X API: https://developer.twitter.com/
# Free tier: 1500 tweets/month. Used to parse @BlrCityTraffic feed.
X_BEARER_TOKEN=

# ===== Bangalore Bounding Box =====
BBOX_MIN_LAT=12.85
BBOX_MAX_LAT=13.15
BBOX_MIN_LON=77.45
BBOX_MAX_LON=77.78
